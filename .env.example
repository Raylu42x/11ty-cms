PORT=3000

# Generate a random string — e.g. openssl rand -hex 32
SESSION_SECRET=change-me-use-a-long-random-string

# Generate with: node -e "require('bcrypt').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# GitHub personal access token with repo scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Identity used for git commits made by the CMS
GIT_USER_NAME=CMS Bot
GIT_USER_EMAIL=cms@example.com

# Where cloned repos are stored. Leave blank to use ./repos/ (dev default).
# In Docker this is set to /repos via docker-compose.yml.
REPOS_DIR=
