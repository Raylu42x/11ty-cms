{
  "name": "11ty-cms",
  "version": "1.0.0",
  "description": "Self-hosted CMS for 11ty sites on GitHub Pages",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "gray-matter": "^4.0.3",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "simple-git": "^3.25.0"
  }
}
